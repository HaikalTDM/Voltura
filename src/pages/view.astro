---
// /view?id=SESSION_ID
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Voltura — Live</title>
  <style>
    :root {
      --bg: #0A0A0A; --surface: #141414; --border: #2A2A2A;
      --volt: #FFD700; --volt-dim: rgba(255,215,0,0.06);
      --text: #FFFFFF; --text-dim: #777777;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: var(--bg); color: var(--text);
      font-family: system-ui, -apple-system, sans-serif;
      min-height: 100dvh; display: flex; flex-direction: column;
    }
    header {
      text-align: center; padding: 1rem; border-bottom: 1px solid var(--border);
      background: var(--bg); position: sticky; top: 0; z-index: 10;
    }
    header h1 {
      color: var(--volt); font-size: 1.25rem;
      letter-spacing: 0.1em; text-transform: uppercase; font-weight: 800;
    }
    .container {
      max-width: 640px; width: 100%; margin: 0 auto;
      padding: 1rem; display: flex; flex-direction: column; gap: 1rem;
    }
    .card {
      background: var(--surface); border: 1px solid var(--border);
      padding: 1.25rem 1.5rem;
    }
    .card h2 {
      color: var(--volt); font-size: 0.7rem; text-transform: uppercase;
      letter-spacing: 0.18em; border-bottom: 2px solid var(--volt);
      padding-bottom: 0.4rem; display: inline-block; margin-bottom: 0.75rem;
    }
    .stat-row {
      display: flex; justify-content: center; gap: 1.5rem;
      font-size: 0.75rem; color: var(--text-dim); margin-bottom: 0.5rem;
      text-transform: uppercase; letter-spacing: 0.06em;
    }
    .stat-row span { color: var(--text); font-weight: 600; }
    .live-dot {
      display: inline-block; width: 8px; height: 8px; border-radius: 50%;
      background: #3BFF6B; margin-right: 4px; animation: pulse 1.5s infinite;
    }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.3} }
    .court-lane {
      border-left: 3px solid var(--volt); padding: .8rem 1rem;
      margin-bottom: .75rem; background: var(--volt-dim);
    }
    .court-lane:last-child { margin-bottom: 0; }
    .court-label {
      font-size: .5rem; text-transform: uppercase; letter-spacing: .12em;
      color: var(--volt); margin-bottom: .6rem; text-align: center;
    }
    .teams { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: .6rem; }
    .team { text-align: center; }
    .player { display: block; font-size: .9rem; font-weight: 700; line-height: 1.6; }
    .vs { color: var(--volt); font-weight: 800; font-size: 1rem; }
    .round-list { list-style: none; display: flex; flex-direction: column; gap: .3rem; }
    .round-list li {
      padding: .35rem .5rem; background: var(--bg); border: 1px solid var(--border); font-size: .75rem;
    }
    .round-list li.active { border-color: var(--volt); background: var(--volt-dim); }
    .empty { color: var(--text-dim); font-size: .85rem; text-align: center; padding: 2rem 0; }
  </style>
</head>
<body>
  <header>
    <h1><span class="live-dot"></span>Voltura Live</h1>
  </header>
  <div class="container" id="app">
    <div class="empty">Loading session...</div>
  </div>

  <script type="module">
    import { getSession, subscribeSession } from '../lib/supabase.js';

    const params = new URLSearchParams(window.location.search);
    const id = params.get('id');
    const app = document.getElementById('app');

    if (!id) { app.innerHTML = '<div class="empty">No session ID provided</div>'; }

    function esc(s) {
      return String(s).replace(/[&<>"']/g, c =>
        ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' })[c]);
    }

    function render(s) {
      if (!s) { app.innerHTML = '<div class="empty">Session not found</div>'; return; }
      const courts = s.courtCount || 1;
      const active = s.activeMatches || [];
      const schedule = s.schedule || [];
      const idx = s.scheduleIdx || 0;
      const recent = (s.matches || []).slice(-3).reverse();
      const dur = s.sessionDuration || 180;
      const h = Math.floor(dur / 60); const m = dur % 60;

      let courtHtml = '';
      if (active.length > 0) {
        active.forEach((m, i) => {
          courtHtml += `<div class="court-lane">
            <div class="court-label">Court ${i + 1}</div>
            <div class="teams">
              <div class="team"><span class="player">${esc(m.teamA[0])}</span><span class="player">${esc(m.teamA[1])}</span></div>
              <span class="vs">VS</span>
              <div class="team"><span class="player">${esc(m.teamB[0])}</span><span class="player">${esc(m.teamB[1])}</span></div>
            </div>
          </div>`;
        });
      } else if (s.players.length < courts * 4) {
        courtHtml = '<div class="empty">Waiting for players...</div>';
      } else {
        courtHtml = '<div class="empty">Round ended — next round loading...</div>';
      }

      let scheduleHtml = '';
      for (let i = idx; i < Math.min(idx + 5, schedule.length); i++) {
        const round = schedule[i];
        const parts = round.map((m, ci) => {
          const a = m.teamA.join('/'); const b = m.teamB.join('/');
          return (courts > 1 ? `C${ci+1} ` : '') + `${esc(a)} vs ${esc(b)}`;
        });
        scheduleHtml += `<li class="${i===idx?'active':''}">${i===idx?'▶ ':''}R${i+1}: ${parts.join(' · ')}</li>`;
      }

      let recentHtml = '';
      recent.forEach((round) => {
        round.forEach((m) => {
          recentHtml += `<li>${esc(m.teamA.join('/'))} ${m.scoreA} - ${m.scoreB} ${esc(m.teamB.join('/'))}</li>`;
        });
      });

      app.innerHTML = `
        <div class="card"><h2>Active Courts — Round ${idx+1}/${schedule.length}</h2>${courtHtml}</div>
        <div class="card"><h2>Upcoming</h2>${scheduleHtml?`<ul class="round-list">${scheduleHtml}</ul>`:'<div class="empty">No schedule</div>'}</div>
        ${recentHtml?`<div class="card"><h2>Recent Scores</h2><ul class="round-list">${recentHtml}</ul></div>`:''}
        <div class="card"><div class="stat-row"><span>${s.players.length}</span> players <span>${courts}</span> court${courts>1?'s':''} <span>${h>0?h+'h ':''}${m}m</span></div></div>`;
    }

    if (id) {
      const initial = await getSession(id);
      render(initial);
      subscribeSession(id, render);
    }
  </script>
</body>
</html>
