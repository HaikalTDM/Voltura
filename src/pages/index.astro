---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="page-content">
    <section class="card" id="card-court">
      <h2>Active Courts — <span id="round-label"></span></h2>
      <div id="court-content" class="empty-state">Add 4+ players per court in Roster to start</div>
      <div class="row mt" style="gap:0.5rem;display:none" id="court-actions">
        <button id="btn-finish" class="primary" style="flex:1">Finish Round</button>
        <button id="btn-undo" class="small" style="display:none">Undo</button>
      </div>
    </section>

    <section class="card" id="card-settings" style="display:none">
      <h2>Session Setup</h2>
      <div class="row" style="align-items:center;gap:0.5rem;margin-bottom:0.5rem">
        <input type="number" id="session-duration" min="10" max="480" step="5" value="180" style="flex:1" />
        <span style="font-size:0.75rem;color:var(--text-dim);white-space:nowrap">min</span>
        <button id="btn-set-duration" class="small" style="white-space:nowrap">Set</button>
        <button id="btn-edit-duration" class="small" style="display:none;white-space:nowrap">Edit</button>
      </div>
      <div class="row" style="align-items:center;gap:0.5rem">
        <span style="font-size:0.65rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-dim);white-space:nowrap">Courts</span>
        <input type="number" id="court-count" min="1" max="4" step="1" value="1" style="width:60px;text-align:center" />
        <span style="font-size:0.65rem;color:var(--text-dim)" id="court-players-label">4/round</span>
      </div>
    </section>

    <section class="card" id="card-schedule" style="display:none">
      <h2>Schedule <span id="schedule-duration" style="font-weight:400;letter-spacing:0;text-transform:none;color:var(--text-dim)"></span></h2>
      <div id="schedule-content"></div>
      <button id="btn-export-schedule" class="primary full mt" style="display:none">Export Schedule</button>
    </section>

    <section class="card" id="card-bench" style="display:none">
      <h2>Bench</h2>
      <div id="bench-content"></div>
    </section>

    <section class="card" id="card-end" style="display:none">
      <button id="btn-end-session" class="danger full">End Session — View Results</button>
    </section>
  </main>

  <div class="modal-overlay" id="modal-score">
    <div class="modal" style="width:360px">
      <h3>Enter Scores</h3>
      <div id="score-courts"></div>
      <div class="modal-actions" style="margin-top:0.75rem">
        <button id="btn-cancel-score">Cancel</button>
        <button id="btn-save-score" class="primary">Save</button>
      </div>
    </div>
  </div>
</Layout>

<script>
  function esc(s) {
    return String(s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c]);
  }
  function shuffle(arr) { const a = [...arr]; for (let i = a.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); [a[i], a[j]] = [a[j], a[i]]; } return a; }

  const KEY = 'voltura_session';
  const PHOTO_KEY = 'voltura_photos';
  const MIN_PER_GAME = 9;
  function load() { const r = localStorage.getItem(KEY); return r ? JSON.parse(r) : null; }
  function save(s2) { localStorage.setItem(KEY, JSON.stringify(s2)); }
  function loadPhotos() { const r = localStorage.getItem(PHOTO_KEY); return r ? JSON.parse(r) : {}; }
  function calcRounds(dur) { return Math.max(1, Math.floor(dur / MIN_PER_GAME)); }

  let s = null, photos = {};

  function photoImg(name, size) {
    const sz = size || 22; const pic = photos[name];
    const style = `display:inline-block;width:${sz}px;height:${sz}px;border-radius:50%;overflow:hidden;vertical-align:middle;margin:0 3px;border:1px solid var(--border);flex-shrink:0`;
    if (pic) return `<span style="${style}"><img src="${pic}" style="width:100%;height:100%;object-fit:cover" /></span>`;
    const colors = ['#FFD700','#FF6B6B','#4ECDC4','#45B7D1','#96CEB4','#FFEAA7','#DDA0DD','#98D8C8'];
    const ci = name.charCodeAt(0) % colors.length;
    const fs = Math.max(8, Math.floor(sz * 0.45));
    return `<span style="${style};background:${colors[ci]};color:#0A0A0A;font-weight:700;font-size:${fs}px;text-align:center;line-height:${sz}px;text-transform:uppercase">${name[0]}</span>`;
  }

  function activeNames() {
    if (!s || !s.activeMatches) return [];
    return s.activeMatches.flatMap((m) => [...m.teamA, ...m.teamB]);
  }

  function ensureSchedule() {
    if (!s) return;
    const names = s.players.filter((p) => !p.left).map((p) => p.name);
    const courts = s.courtCount || 1;
    const perRound = courts * 4;
    if (names.length < perRound) return;

    if (!s.schedule) { s.schedule = []; s.scheduleIdx = 0; }
    if (!s.activeMatches) s.activeMatches = [];

    if (s.scheduleIdx >= s.schedule.length && s.schedule.length > 0) {
      const counts = {};
      names.forEach((n) => { counts[n] = 0; });
      (s.matches || []).forEach((mr) => {
        mr.forEach((m) => {
          [...m.teamA, ...m.teamB].forEach((n) => { if (counts[n] !== undefined) counts[n]++; });
        });
      });
      s.schedule.forEach((r) => {
        r.forEach((m) => {
          [...m.teamA, ...m.teamB].forEach((n) => { if (counts[n] !== undefined) counts[n]++; });
        });
      });
      const EXTEND = 5;
      for (let k = 0; k < EXTEND; k++) {
        const sorted = shuffle(names).sort((a, b) => (counts[a] || 0) - (counts[b] || 0));
        const pick = sorted.slice(0, perRound);
        const round = [];
        for (let c = 0; c < courts; c++) {
          const t = shuffle(pick.slice(c * 4, c * 4 + 4));
          round.push({ teamA: [t[0], t[1]], teamB: [t[2], t[3]] });
        }
        s.schedule.push(round);
        pick.forEach((n) => { counts[n] = (counts[n] || 0) + 1; });
      }
    }

    if (s.schedule.length === 0) {
      const target = calcRounds(s.sessionDuration || 180);
      const counts = {};
      names.forEach((n) => { counts[n] = 0; });
      (s.matches || []).forEach((mr) => {
        mr.forEach((m) => {
          [...m.teamA, ...m.teamB].forEach((n) => { if (counts[n] !== undefined) counts[n]++; });
        });
      });
      while (s.schedule.length < target) {
        const sorted = shuffle(names).sort((a, b) => (counts[a] || 0) - (counts[b] || 0));
        const pick = sorted.slice(0, perRound);
        const round = [];
        for (let c = 0; c < courts; c++) {
          const t = shuffle(pick.slice(c * 4, c * 4 + 4));
          round.push({ teamA: [t[0], t[1]], teamB: [t[2], t[3]] });
        }
        s.schedule.push(round);
        pick.forEach((n) => { counts[n] = (counts[n] || 0) + 1; });
      }
      s.scheduleIdx = 0;
    }

    s.activeMatches = s.schedule[s.scheduleIdx] || [];
  }

  function refresh() {
    s = load();
    if (!s) { document.body.classList.add('ready'); return; }
    photos = loadPhotos();
    if (s.sessionDuration == null) s.sessionDuration = 180;
    if (s.courtCount == null) s.courtCount = 1;
    if (s.activeMatch && !s.activeMatches) {
      s.activeMatches = [s.activeMatch];
      delete s.activeMatch;
    }
    if (s.matches && s.matches.length > 0 && !Array.isArray(s.matches[0])) {
      s.matches = s.matches.map((m) => [m]);
    }
    if (s.schedule && s.schedule.length > 0 && !Array.isArray(s.schedule[0])) {
      s.schedule = s.schedule.map((r) => [r]);
    }
    if (s.players.length >= s.courtCount * 4) {
      ensureSchedule();
      save(s);
    }
    render();
    document.body.classList.add('ready');
  }

  function persist() { save(s); render(); }

  function render() {
    renderCourt();
    renderSchedule();
    renderBench();
    const endCard = document.getElementById('card-end');
    endCard.style.display = (s && s.matches && s.matches.length > 0) ? '' : 'none';
    document.getElementById('btn-undo').style.display = (s && s.matches && s.matches.length > 0) ? '' : 'none';

    const settingsCard = document.getElementById('card-settings');
    if (s && s.players.length >= s.courtCount * 4) {
      settingsCard.style.display = '';
      const durInput = document.getElementById('session-duration');
      durInput.value = s.sessionDuration || 180;
      const ccInput = document.getElementById('court-count');
      ccInput.value = s.courtCount || 1;
      document.getElementById('court-players-label').textContent = `${(s.courtCount || 1) * 4}/round`;
      if (s.durationLocked) lockDuration(); else unlockDuration();
    } else {
      settingsCard.style.display = 'none';
    }
  }

  function renderCourt() {
    const el = document.getElementById('court-content');
    const actions = document.getElementById('court-actions');
    const label = document.getElementById('round-label');

    if (s && s.activeMatches && s.activeMatches.length > 0) {
      const idx = s.scheduleIdx != null ? s.scheduleIdx + 1 : '';
      label.textContent = idx ? `Round ${idx}/${s.schedule.length}` : '';

      const courts = s.courtCount || 1;
      let html = '';
      for (let c = 0; c < courts; c++) {
        const m = s.activeMatches[c];
        if (!m) continue;
        html += `<div class="court-lane">
          <div class="court-label">Court ${c + 1}</div>
          <div class="teams" style="gap:0.5rem">
            <div class="team"><span class="player" style="font-size:0.85rem">${photoImg(m.teamA[0],24)}${esc(m.teamA[0])}</span><span class="player" style="font-size:0.85rem">${photoImg(m.teamA[1],24)}${esc(m.teamA[1])}</span></div>
            <span class="vs" style="font-size:1rem">VS</span>
            <div class="team"><span class="player" style="font-size:0.85rem">${photoImg(m.teamB[0],24)}${esc(m.teamB[0])}</span><span class="player" style="font-size:0.85rem">${photoImg(m.teamB[1],24)}${esc(m.teamB[1])}</span></div>
          </div>
        </div>`;
      }
      el.innerHTML = html;
      el.classList.remove('empty-state');
      actions.style.display = '';
    } else {
      label.textContent = '';
      const needed = (s ? s.courtCount || 1 : 1) * 4;
      const count = s ? s.players.length : 0;
      if (count === 0) el.textContent = `Add ${needed}+ players in Roster to start`;
      else if (count < needed) el.textContent = `Need ${needed - count} more player(s)`;
      else el.textContent = 'Generating schedule...';
      el.classList.add('empty-state');
      actions.style.display = 'none';
    }
  }

  function renderSchedule() {
    const card = document.getElementById('card-schedule');
    const el = document.getElementById('schedule-content');
    if (!s || !s.schedule || s.schedule.length === 0) { card.style.display = 'none'; return; }
    card.style.display = '';

    const idx = s.scheduleIdx || 0;
    const PREVIEW = 5;
    const remaining = s.schedule.length - idx;
    const expanded = el.dataset.expanded === '1';
    const limit = expanded ? remaining : Math.min(PREVIEW, remaining);
    const hasMore = remaining > PREVIEW;

    const totalMin = remaining * MIN_PER_GAME;
    const h = Math.floor(totalMin / 60); const m2 = totalMin % 60;
    document.getElementById('schedule-duration').textContent = `\u00b7 ${remaining} rounds left \u00b7 ${h > 0 ? `~${h}h ${m2}m` : `~${m2}m`}`;

    const playCounts = {};
    s.players.forEach((p) => { playCounts[p.name] = 0; });
    s.schedule.forEach((r) => { r.forEach((m) => { [...m.teamA, ...m.teamB].forEach((n) => { if (playCounts[n] !== undefined) playCounts[n]++; }); }); });

    const courts = s.courtCount || 1;
    let html = '<ul class="player-list">';
    for (let i = idx; i < idx + limit; i++) {
      const round = s.schedule[i];
      const isNow = i === idx;
      let parts = round.map((m, ci) => {
        const a = m.teamA.join('/'); const b = m.teamB.join('/');
        return (courts > 1 ? `C${ci + 1} ` : '') + `${esc(a)} <span style="color:var(--volt)">vs</span> ${esc(b)}`;
      });
      html += `<li style="${isNow ? 'border-color:var(--volt);background:var(--volt-dim)' : ''}">
        <span style="font-size:0.78rem;flex:1;${isNow ? 'color:var(--volt);font-weight:700' : 'color:var(--text-dim)'}">
          ${isNow ? '\u25b6 ' : ''}R${i + 1}: ${parts.join(' <span style="color:var(--text-dim);font-size:0.65rem">|</span> ')}
        </span>
      </li>`;
    }
    html += '</ul>';

    if (hasMore) {
      html += `<button class="small full mt" id="btn-toggle-schedule">${expanded ? 'Show less' : `Show all ${remaining} rounds`}</button>`;
    }

    const minPlays = Math.min(...Object.values(playCounts));
    const maxPlays = Math.max(...Object.values(playCounts));
    const range = minPlays === maxPlays ? `${minPlays} games each` : `${minPlays}\u2013${maxPlays} games each`;
    html += `<div style="font-size:0.65rem;color:var(--text-dim);margin-top:0.5rem;text-align:center;letter-spacing:0.06em;text-transform:uppercase">${range} \u00b7 ${s.schedule.length} rounds \u00b7 ${MIN_PER_GAME} min/game</div>`;

    el.innerHTML = html;
    const btn = el.querySelector('#btn-toggle-schedule');
    if (btn) btn.addEventListener('click', () => { el.dataset.expanded = expanded ? '0' : '1'; renderSchedule(); });
    document.getElementById('btn-export-schedule').style.display = '';
  }

  function renderBench() {
    const card = document.getElementById('card-bench');
    const el = document.getElementById('bench-content');
    if (!s || !s.activeMatches || s.activeMatches.length === 0) { card.style.display = 'none'; return; }
    const active = activeNames();
    const bench = s.players.filter((p) => !p.left && !active.includes(p.name)).map((p) => p.name);
    if (bench.length === 0) { card.style.display = 'none'; return; }
    card.style.display = '';
    let html = '<ul class="player-list">';
    bench.forEach((n) => { html += `<li>${photoImg(n,22)}<span class="name">${esc(n)}</span><span class="rating-badge">${s.ratings[n] || 1000}</span></li>`; });
    html += '</ul>';
    el.innerHTML = html;
  }

  function openScoreModal() {
    if (!s || !s.activeMatches) return;
    const el = document.getElementById('score-courts');
    let html = '';
    s.activeMatches.forEach((m, i) => {
      html += `<div style="margin-bottom:0.75rem">
        <div style="font-size:0.6rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--text-dim);margin-bottom:0.25rem">Court ${i + 1}</div>
        <div class="score-inputs" style="grid-template-columns:1fr auto 1fr;gap:0.4rem">
          <input type="number" class="score-in" data-court="${i}" data-team="a" placeholder="A" min="0" max="99" />
          <span class="vs-small">VS</span>
          <input type="number" class="score-in" data-court="${i}" data-team="b" placeholder="B" min="0" max="99" />
        </div>
      </div>`;
    });
    el.innerHTML = html;
    document.getElementById('modal-score').classList.add('open');
    el.querySelector('input').focus();
  }

  function closeScoreModal() { document.getElementById('modal-score').classList.remove('open'); }

  function saveScore() {
    const inputs = document.querySelectorAll('.score-in');
    const scores = {};
    let valid = true;
    inputs.forEach((inp) => {
      const key = inp.dataset.court + '_' + inp.dataset.team;
      scores[key] = inp.value;
      if (inp.value === '' || Number(inp.value) < 0) valid = false;
    });
    if (!valid) return;

    const roundMatches = [];
    s.activeMatches.forEach((m, i) => {
      const scoreA = Number(scores[i + '_a']);
      const scoreB = Number(scores[i + '_b']);
      const ra = (s.ratings[m.teamA[0]] + s.ratings[m.teamA[1]]) / 2;
      const rb = (s.ratings[m.teamB[0]] + s.ratings[m.teamB[1]]) / 2;
      const expectedA = 1 / (1 + Math.pow(10, (rb - ra) / 400));
      const actualA = scoreA > scoreB ? 1 : 0;
      const margin = Math.abs(scoreA - scoreB);
      const K = Math.round(32 * (1 + Math.max(0, margin - 2) * 0.1));
      const changeA = Math.round(K * (actualA - expectedA));
      const changeB = -changeA;

      roundMatches.push({ teamA: [...m.teamA], teamB: [...m.teamB], scoreA, scoreB, changeA, changeB, actualA });

      m.teamA.forEach((n) => {
        s.ratings[n] += changeA;
        const st = s.playerStats[n]; st.gamesPlayed = (st.gamesPlayed || 0) + 1;
        if (actualA) st.wins++; else st.losses++;
      });
      m.teamB.forEach((n) => {
        s.ratings[n] += changeB;
        const st = s.playerStats[n]; st.gamesPlayed = (st.gamesPlayed || 0) + 1;
        if (!actualA) st.wins++; else st.losses++;
      });
    });

    s.matches.push(roundMatches);
    s.scheduleIdx = (s.scheduleIdx || 0) + 1;
    ensureSchedule();
    closeScoreModal();
    persist();
  }

  function undoLast() {
    if (!s || s.matches.length === 0) return;
    const round = s.matches.pop();
    round.forEach((last) => {
      const { teamA, teamB, changeA, changeB, actualA } = last;
      teamA.forEach((n) => {
        s.ratings[n] -= changeA;
        const st = s.playerStats[n]; st.gamesPlayed = Math.max(0, (st.gamesPlayed || 1) - 1);
        if (actualA) st.wins = Math.max(0, st.wins - 1); else st.losses = Math.max(0, st.losses - 1);
      });
      teamB.forEach((n) => {
        s.ratings[n] -= changeB;
        const st = s.playerStats[n]; st.gamesPlayed = Math.max(0, (st.gamesPlayed || 1) - 1);
        if (!actualA) st.wins = Math.max(0, st.wins - 1); else st.losses = Math.max(0, st.losses - 1);
      });
    });
    s.scheduleIdx = Math.max(0, (s.scheduleIdx || 0) - 1);
    s.activeMatches = s.schedule[s.scheduleIdx] || [];
    persist();
  }

  function regenerateSchedule() {
    if (!s || s.players.length < (s.courtCount || 1) * 4) return;
    s.schedule = []; s.scheduleIdx = 0; s.activeMatches = [];
    delete document.getElementById('schedule-content').dataset.expanded;
    ensureSchedule(); persist();
  }

  function lockDuration() {
    const input = document.getElementById('session-duration');
    const setBtn = document.getElementById('btn-set-duration');
    const editBtn = document.getElementById('btn-edit-duration');
    input.disabled = true; input.style.opacity = '0.5';
    setBtn.style.display = 'none'; editBtn.style.display = '';
  }
  function unlockDuration() {
    const input = document.getElementById('session-duration');
    const setBtn = document.getElementById('btn-set-duration');
    const editBtn = document.getElementById('btn-edit-duration');
    input.disabled = false; input.style.opacity = '';
    setBtn.style.display = ''; editBtn.style.display = 'none';
  }
  function endSession() {
    if (!s || s.matches.length === 0) return;
    if (!confirm('End this session and view the results?')) return;
    window.location.href = '/summary';
  }

  async function exportSchedule() {
    if (!s || !s.schedule || s.schedule.length === 0) return;
    const btn = document.getElementById('btn-export-schedule'); btn.textContent = '...'; btn.disabled = true;
    try {
      const scheduleEl = document.getElementById('schedule-content');
      const wasExpanded = scheduleEl.dataset.expanded === '1';
      if (!wasExpanded) { scheduleEl.dataset.expanded = '1'; renderSchedule(); await new Promise((r) => requestAnimationFrame(r)); }
      const h2c = (await import('html2canvas')).default;
      const canvas = await h2c(document.getElementById('card-schedule'), { backgroundColor: '#0A0A0A', scale: 2, logging: false });
      if (!wasExpanded) { scheduleEl.dataset.expanded = '0'; renderSchedule(); }
      const blob = await new Promise((r) => canvas.toBlob(r, 'image/png'));
      const file = new File([blob], 'voltura-schedule.png', { type: 'image/png' });
      if (navigator.share) { try { await navigator.share({ files: [file], title: 'Voltura Schedule' }); } catch { dl(blob); } }
      else dl(blob);
    } catch (e) { console.error(e); Voltura.toast('Export failed'); }
    btn.textContent = 'Export Schedule'; btn.disabled = false;
  }
  function dl(blob) { const url = URL.createObjectURL(blob); const a = document.createElement('a'); a.href = url; a.download = 'voltura-schedule.png'; a.click(); URL.revokeObjectURL(url); }

  refresh();
  document.getElementById('btn-finish').addEventListener('click', openScoreModal);
  document.getElementById('btn-undo').addEventListener('click', undoLast);
  document.getElementById('btn-export-schedule').addEventListener('click', exportSchedule);
  document.getElementById('btn-cancel-score').addEventListener('click', closeScoreModal);
  document.getElementById('btn-save-score').addEventListener('click', saveScore);
  document.getElementById('modal-score').addEventListener('click', (e) => { if (e.target === e.currentTarget) closeScoreModal(); });
  document.getElementById('btn-set-duration').addEventListener('click', () => {
    const val = Number(document.getElementById('session-duration').value) || 180;
    s.sessionDuration = val; s.durationLocked = true;
    s.schedule = []; s.scheduleIdx = 0; s.activeMatches = [];
    ensureSchedule(); lockDuration(); persist();
  });
  document.getElementById('btn-edit-duration').addEventListener('click', async () => {
    if (!(await Voltura.confirm('Changing session length will regenerate the schedule. Continue?'))) return;
    s.durationLocked = false; unlockDuration();
  });
  document.getElementById('btn-end-session').addEventListener('click', endSession);
  document.getElementById('court-count').addEventListener('change', () => {
    const cc = Math.max(1, Math.min(4, Number(document.getElementById('court-count').value) || 1));
    s.courtCount = cc;
    document.getElementById('court-players-label').textContent = `${cc * 4}/round`;
    s.schedule = []; s.scheduleIdx = 0; s.activeMatches = [];
    if (s.players.length >= cc * 4) ensureSchedule();
    persist();
  });
</script>

<style>
  .court-lane {
    border: 1px solid var(--border);
    padding: 0.6rem;
    margin-bottom: 0.5rem;
  }
  .court-lane:last-child { margin-bottom: 0; }
  .court-label {
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-dim);
    margin-bottom: 0.4rem;
    text-align: center;
  }
</style>
